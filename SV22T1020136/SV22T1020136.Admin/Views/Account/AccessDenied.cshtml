@{
    ViewBag.Title = "Không có quyền";
    Layout = null;
}
<!doctype html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title</title>
    <link rel="stylesheet" href="~/lib/bootstrap/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/lib/adminlte/css/adminlte.css" />
</head>
<body class="login-page bg-body-secondary">
    <div class="login-box">
        <div class="card">
            <div class="card-body text-center p-4">
                <h1 class="h4 text-danger">Truy cập bị từ chối</h1>
                <p class="mb-3">Bạn không có quyền xem trang này.</p>
                <a class="btn btn-primary" href="~/">Về trang chủ</a>
                <a class="btn btn-outline-secondary ms-2" href="~/Account/Login">Đăng nhập</a>
            </div>
        </div>
    </div>
</body>
</html>

@using SV22T1020136.Models
@using SV22T1020136.Models.Sales
@using ProductModel = SV22T1020136.Models.Product
@using CustomerModel = SV22T1020136.Models.Customer
@{
    ViewBag.Title = "Lập đơn hàng";
    var products = ViewBag.Products as List<ProductModel> ?? new List<ProductModel>();
    var customers = ViewBag.Customers as List<CustomerModel> ?? new List<CustomerModel>();
    var cart = ViewBag.Cart as List<OrderDetail> ?? new List<OrderDetail>();
    var cartProducts = ViewBag.CartProducts as Dictionary<int, ProductModel> ?? new Dictionary<int, ProductModel>();

    var searchValue = ViewBag.SearchValue as string ?? "";
    var currentPage = ViewBag.Page as int? ?? 1;
    var pageSize = ViewBag.PageSize as int? ?? 5;
    var rowCount = ViewBag.RowCount as int? ?? 0;
    var totalPages = (int)Math.Ceiling(rowCount / (pageSize <= 0 ? 1.0 : (double)pageSize));

    decimal total = 0m;
    foreach (var item in cart)
        total += item.Quantity * item.SalePrice;
}

<div class="row">
    <div class="col-4">
        <div class="card card-outline card-primary h-100">
            <div class="card-header">
                <h5 class="mb-0">
                    <i class="bi bi-search"></i>
                    Lựa chọn hàng cần bán
                </h5>
            </div>

            <div class="card-body">
                <form method="get" asp-action="Create" asp-controller="Order" class="mb-3">
                    <div class="input-group">
                        <input class="form-control"
                               name="searchValue"
                               value="@searchValue"
                               placeholder="Nhập tên mặt hàng cần tìm" autofocus />
                        <button class="btn btn-primary">
                            <i class="bi bi-search"></i>
                        </button>
                    </div>
                </form>

                @foreach (var p in products)
                {
                    var photo = string.IsNullOrWhiteSpace(p.Photo)
                        ? Url.Content("~/images/products/nophoto.png")
                        : (p.Photo.StartsWith("http", StringComparison.OrdinalIgnoreCase) ? p.Photo : Url.Content("~/images/products/" + p.Photo));
                    <form method="post"
                          asp-action="AddCartItem" asp-controller="Order"
                          class="border rounded p-2 mb-2">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="0" />
                        <input type="hidden" name="productId" value="@p.ProductID" />
                        <input type="hidden" name="salePrice" value="@p.Price" />
                        <input type="hidden" name="returnSearchValue" value="@searchValue" />
                        <input type="hidden" name="returnPage" value="@currentPage" />
                        <strong>@p.ProductName</strong>

                        <div class="row mt-2">
                            <div class="col-4">
                                <img src="@photo"
                                     class="img-fluid border" style="max-height:100px" />
                            </div>
                            <div class="col-8">
                                <div class="row g-2">
                                    <div class="col-7">
                                        <label class="form-label mb-0">Giá</label>
                                        <input class="form-control form-control-sm money-input"
                                               value="@p.Price" readonly />
                                    </div>
                                    <div class="col-5">
                                        <label class="form-label mb-0">SL</label>
                                        <input type="number"
                                               min="1"
                                               name="quantity"
                                               value="1"
                                               class="form-control form-control-sm" />
                                    </div>
                                </div>

                                <button class="btn btn-sm btn-primary mt-2 w-100" type="submit">
                                    <i class="bi bi-cart-plus"></i>
                                    Thêm vào giỏ
                                </button>
                            </div>
                        </div>
                    </form>
                }
            </div>

            <div class="card-footer">
                <ul class="pagination justify-content-between mb-0">
                    <li class="page-item">
                        <a class="page-link" href="@Url.Action("Create", "Order", new { searchValue, page = Math.Max(1, currentPage - 1), pageSize })">
                            <i class="bi bi-chevron-left"></i>
                        </a>
                    </li>
                    <li class="page-item">
                        <a class="page-link" href="@Url.Action("Create", "Order", new { searchValue, page = Math.Min(totalPages, currentPage + 1) })">
                            <i class="bi bi-chevron-right"></i>
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    </div>

    <div class="col-8">
        <div class="row">
            <div class="col-12">
                <div class="card card-outline card-success">
                    <div class="card-header">
                        <h5 class="mb-0">
                            <i class="bi bi-cart"></i>
                            Danh sách mặt hàng đã chọn
                        </h5>
                    </div>

                    <div class="card-body">
                        <table class="table table-bordered table-hover align-middle">
                            <thead class="table-success">
                                <tr>
                                    <th class="text-center">#</th>
                                    <th style="width:auto">Tên hàng</th>
                                    <th class="text-center" style="width:100px">ĐVT</th>
                                    <th class="text-center" style="width:100px">SL</th>
                                    <th class="text-end" style="width:150px">Giá</th>
                                    <th class="text-end" style="width:150px">Thành tiền</th>
                                    <th style="width:80px"></th>
                                </tr>
                            </thead>
                            <tbody>
                                @{
                                    var index = 0;
                                }
                                @foreach (var item in cart)
                                {
                                    index++;
                                    cartProducts.TryGetValue(item.ProductID, out var p);
                                    var name = p?.ProductName ?? $"#{item.ProductID}";
                                    var unit = p?.Unit ?? "";
                                    var amount = item.Quantity * item.SalePrice;
                                    <tr>
                                        <td class="text-center">@index</td>
                                        <td>@name</td>
                                        <td class="text-center">@unit</td>
                                        <td class="text-center">@item.Quantity</td>
                                        <td class="text-end">@item.SalePrice.ToString("N0")</td>
                                        <td class="text-end">@amount.ToString("N0")</td>
                                        <td class="text-end text-nowrap">
                                            <a class="btn btn-sm btn-primary open-modal"
                                               href="@Url.Action("EditCartItem", "Order", new { id = 0, productId = item.ProductID })">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                            <a class="btn btn-sm btn-danger open-modal"
                                               href="@Url.Action("DeleteCartItem", "Order", new { id = 0, productId = item.ProductID })">
                                                <i class="bi bi-dash"></i>
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot>
                                <tr>
                                    <th colspan="5" class="text-end">Tổng cộng:</th>
                                    <th class="text-end">@total.ToString("N0")</th>
                                    <th></th>
                                </tr>
                            </tfoot>
                        </table>

                        <div class="text-end">
                            <a class="btn btn-sm btn-danger mt-2 open-modal"
                               href="@Url.Action("ClearCart", "Order", new { id = 0 })">
                                <i class="bi bi-trash"></i>
                                Xóa giỏ hàng
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row mt-3">
            <div class="col-12">
                <div class="card card-outline card-info">
                    <div class="card-header">
                        <h5 class="mb-0">
                            <i class="bi bi-person"></i>
                            Thông tin khách hàng & nơi giao hàng
                        </h5>
                    </div>

                    <div class="card-body">
                        <form method="post" asp-action="Create" asp-controller="Order">
                            @Html.AntiForgeryToken()
                            <div class="row mb-3">
                                <label class="col-md-2 col-form-label">Khách hàng</label>
                                <div class="col-md-10">
                                    <select class="form-select" name="CustomerID">
                                        <option value="">-- Chọn khách hàng --</option>
                                        @foreach (var c in customers)
                                        {
                                            <option value="@c.CustomerID">@c.CustomerName</option>
                                        }
                                    </select>
                                </div>
                            </div>

                            <div class="row mb-3">
                                <label class="col-md-2 col-form-label">Tỉnh/thành</label>
                                <div class="col-md-10">
                                    <input class="form-control" name="DeliveryProvince" placeholder="VD: Thừa Thiên Huế" />
                                </div>
                            </div>

                            <div class="row mb-3">
                                <label class="col-md-2 col-form-label">Địa chỉ</label>
                                <div class="col-md-10">
                                    <textarea class="form-control" name="DeliveryAddress" rows="2"></textarea>
                                </div>
                            </div>

                            <div class="text-end">
                                <button class="btn btn-primary" type="submit" @(cart.Count == 0 ? "disabled" : "")>
                                    <i class="bi bi-check-circle"></i>
                                    Lập đơn hàng
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@{
    Layout = null;
    var orderId = ViewBag.OrderId as int? ?? 0;
    var productId = ViewBag.ProductId as int? ?? 0;
}
<form method="post" asp-action="DeleteCartItem" asp-controller="Order">
    @Html.AntiForgeryToken()
    <input type="hidden" name="id" value="@orderId" />
    <input type="hidden" name="productId" value="@productId" />

    <div class="modal-header text-bg-danger">
        <strong class="modal-title">
            Xóa mặt hàng khỏi @(orderId > 0 ? $"đơn #{orderId}" : "giỏ hàng")
        </strong>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
    </div>

    <div class="modal-body">
        <div class="alert alert-danger d-flex align-items-center mb-0">
            <i class="bi bi-info-circle me-2"></i>
            Bạn có muốn xóa mặt hàng này không?
        </div>
    </div>

    <div class="modal-footer">
        <button type="submit" class="btn btn-primary">
            <i class="bi bi-check"></i> Chấp nhận
        </button>
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
    </div>
</form>
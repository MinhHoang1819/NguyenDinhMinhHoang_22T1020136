@using SV22T1020136.Models.Sales
@model OrderDetail
@{
    Layout = null;
    var orderId = ViewBag.OrderId as int? ?? 0;
    var productName = ViewBag.ProductName as string ?? $"Mặt hàng #{Model.ProductID}";
    var photoRaw = ViewBag.ProductPhoto as string ?? "";
    var img = string.IsNullOrWhiteSpace(photoRaw)
        ? Url.Content("~/images/products/nophoto.png")
        : (photoRaw.StartsWith("http", StringComparison.OrdinalIgnoreCase)
            ? photoRaw
            : (photoRaw.StartsWith("~/", StringComparison.OrdinalIgnoreCase)
                ? Url.Content(photoRaw)
                : (photoRaw.StartsWith("/", StringComparison.OrdinalIgnoreCase)
                    ? photoRaw
                    : Url.Content("~/images/products/" + photoRaw.TrimStart('/')))));
}
<form method="post" asp-action="EditCartItem" asp-controller="Order">
    @Html.AntiForgeryToken()
    <input type="hidden" name="id" value="@orderId" />
    <input type="hidden" name="productId" value="@Model.ProductID" />

    <div class="modal-header">
        <strong class="modal-title">
            Cập nhật chi tiết đơn hàng
        </strong>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
    </div>

    <div class="modal-body">
        <div class="container-fluid">
            <div class="row">
                <div class="col-md-8">
                    <div class="row mb-3 align-items-center">
                        <label class="col-sm-4 col-form-label fw-semibold">
                            Mặt hàng
                        </label>
                        <div class="col-sm-8">
                            <input type="text"
                                   class="form-control-plaintext fw-bold"
                                   value="@productName"
                                   readonly>
                        </div>
                    </div>
                    <div class="row mb-3 align-items-center">
                        <label class="col-sm-4 col-form-label fw-semibold">
                            Số lượng
                        </label>
                        <div class="col-sm-5">
                            <input type="number"
                                   name="quantity"
                                   class="form-control text-end"
                                   min="1"
                                   value="@Model.Quantity">
                        </div>
                    </div>
                    <div class="row mb-3 align-items-center">
                        <label class="col-sm-4 col-form-label fw-semibold">
                            Đơn giá
                        </label>
                        <div class="col-sm-5">
                            <input type="text"
                                   name="salePrice"
                                   class="form-control text-end money-input"
                                   value="@Model.SalePrice.ToString("N0")">
                        </div>
                    </div>
                </div>
                <div class="col-md-4 text-end">
                    <img src="@img"
                         alt="@productName"
                         class="img-thumbnail"
                         onerror="this.onerror=null;this.src='@Url.Content("~/images/products/nophoto.png")';"
                         style="max-height:180px">
                </div>
            </div>
        </div>
    </div>

    <div class="modal-footer">
        <button type="submit" class="btn btn-primary">
            Cập nhật
        </button>
        <button type="button"
                class="btn btn-secondary"
                data-bs-dismiss="modal">
            Đóng
        </button>
    </div>
</form>

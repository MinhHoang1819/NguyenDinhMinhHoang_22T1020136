@using SV22T1020136.Models.Sales;
@using SV22T1020136.Models

@{
    Layout = null;
    var currentPage = (int)(ViewBag.CurrentPage ?? 1);
    var totalPages = (int)(ViewBag.TotalPages ?? 1);
    var totalRecords = (int)(ViewBag.TotalRecords ?? 0);
}
<div class="mb-2 text-muted">
    Danh sách này có <strong>@totalRecords</strong> đơn hàng
</div>

<div class="card">
    <div class="card-body p-1">
        <table class="table table-bordered table-hover mb-0 align-middle">
            <thead class="table-secondary">
                <tr>
                    <th>Ngày đặt hàng</th>
                    <th>Tên khách hàng</th>
                    <th>Điện thoại</th>
                    <th>Ngày duyệt</th>
                    <th>Nhân viên xử lý</th>
                    <th class="text-end">Tổng tiền</th>
                    <th class="text-center" style="width:140px;">Trạng thái</th>
                    <th class="text-center" style="width:40px"></th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.OrderTime.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>@item.CustomerName</td>
                            <td>@item.CustomerPhone</td>
                            <td>@(item.AcceptTime?.ToString("dd/MM/yyyy HH:mm") ?? "—")</td>
                            <td>@item.EmployeeName</td>
                            <td class="text-end">@item.TotalAmount.ToString("N0")</td>
                            <td class="text-center">
                                <span class="badge bg-warning text-dark">
                                    @(item.StatusDescription ?? item.Status)
                                </span>
                            </td>
                            <td class="text-center text-nowrap">
                                <a href="~/Order/Detail/@item.OrderID" class="btn btn-sm btn-primary">
                                    <i class="bi bi-receipt"></i>
                                </a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="8" class="text-center text-muted">
                            Không có đơn hàng
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="card-footer">
        <ul class="pagination justify-content-center mb-0">
            @for (int p = 1; p <= totalPages; p++)
            {
                <li class="page-item">
                    <a class="page-link" href="javascript:;"
                       onclick="paginationSearch(event, document.getElementById('formSearch'), @p)">
                        @p
                    </a>
                </li>
            }
        </ul>
    </div>
</div>

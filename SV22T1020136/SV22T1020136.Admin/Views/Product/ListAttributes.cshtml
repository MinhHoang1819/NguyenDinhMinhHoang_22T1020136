@using SV22T1020136.Models.Catalog
@model List<SV22T1020136.Models.ProductAttribute>
@{
    Layout = null;
    var productId = ViewBag.ProductID as int? ?? 0;
}
<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-success card-outline mt-4">
            <div class="card-header">
                <div class="row">
                    <div class="col">
                        <h6 id="attributes" class="card-title mb-0">
                            <i class="bi bi-list-check me-2"></i>
                            Thuộc tính mặt hàng
                        </h6>
                    </div>
                    <div class="col text-end">
                        <a class="btn btn-sm btn-primary" href="@Url.Action("AddAttribute", "Product", new { id = productId })">
                            <i class="bi bi-plus"></i>
                            Thêm thuộc tính
                        </a>
                    </div>
                </div>
            </div>
            <div class="card-body p-1">
                <table class="table table-bordered table-hover mb-0">
                    <thead class="table-secondary">
                        <tr>
                            <th>Tên thuộc tính</th>
                            <th>Giá trị</th>
                            <th style="width:120px" class="text-center">Thứ tự</th>
                            <th style="width:120px"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Any())
                        {
                            foreach (var attr in Model.OrderBy(a => a.DisplayOrder))
                            {
                                <tr>
                                    <td>@attr.AttributeName</td>
                                    <td>@attr.AttributeValue</td>
                                    <td class="text-center">@attr.DisplayOrder</td>
                                    <td class="text-center text-nowrap">
                                        <a class="btn btn-sm btn-primary" href="@Url.Action("EditAttribute", "Product", new { id = productId, attributeId = attr.AttributeID })">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <form asp-action="DeleteAttribute" asp-controller="Product" method="post" style="display:inline" onsubmit="return confirm('Xóa thuộc tính này?');">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@productId" />
                                            <input type="hidden" name="attributeId" value="@attr.AttributeID" />
                                            <button type="submit" class="btn btn-sm btn-danger"><i class="bi bi-trash"></i></button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4" class="text-center text-muted">Chưa có thuộc tính</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

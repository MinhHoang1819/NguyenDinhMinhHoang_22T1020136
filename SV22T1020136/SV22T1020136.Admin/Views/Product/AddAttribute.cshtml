@using SV22T1020136.Models
@using SV22T1020136.Models.Catalog
@model SV22T1020136.Models.ProductAttribute
@{
    ViewData["Title"] = "Thêm Thuộc Tính";
    var productID = ViewBag.ProductID as int? ?? 0;
    var productName = ViewBag.ProductName as string ?? "";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card card-primary">
            <div class="card-header">
                <h3 class="card-title">
                    <i class="bi bi-tags me-2"></i>Thêm Thuộc Tính
                </h3>
            </div>
            <form asp-action="SaveAttribute" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="ProductID" />
                <div class="card-body">
                    <div class="alert alert-info">
                        <i class="bi bi-info-circle me-2"></i>
                        <strong>Sản phẩm:</strong> @productName
                    </div>
                    <div class="form-group mb-3">
                        <label asp-for="AttributeName"><i class="bi bi-tag me-1"></i>Tên thuộc tính</label>
                        <input asp-for="AttributeName" class="form-control" required />
                    </div>
                    <div class="form-group mb-3">
                        <label asp-for="AttributeValue"><i class="bi bi-card-text me-1"></i>Giá trị</label>
                        <input asp-for="AttributeValue" class="form-control" required />
                    </div>
                    <div class="form-group mb-3">
                        <label asp-for="DisplayOrder"><i class="bi bi-sort-numeric-down me-1"></i>Thứ tự hiển thị</label>
                        <input asp-for="DisplayOrder" type="number" class="form-control" min="0" />
                    </div>
                </div>
                <div class="card-footer">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-circle me-2"></i>Lưu
                    </button>
                    <a href="@Url.Action("Details", "Product", new { id = productID })" class="btn btn-secondary">
                        <i class="bi bi-x-circle me-2"></i>Hủy
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@using SV22T1020136.Models.Catalog
@using SV22T1020136.Models.Partner
@model SV22T1020136.Models.Product

@section PageToolBar {
    <button type="submit" form="formEdit" class="btn btn-primary">
        <i class="bi bi-save"></i>
        Lưu dữ liệu
    </button>
    <a href="~/Product" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}

<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-primary card-outline">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-box-seam me-2"></i>
                    Thông tin mặt hàng
                </h5>
            </div>

            <div class="card-body">
                <form id="formEdit" method="post" asp-action="Save" asp-controller="Product" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    <input asp-for="ProductID" type="hidden" />
                    <input asp-for="Photo" type="hidden" />

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Tên mặt hàng</label>
                        <div class="col-sm-9">
                            <input asp-for="ProductName" class="form-control" placeholder="Nhập tên mặt hàng" autofocus />
                            <span asp-validation-for="ProductName" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Loại hàng</label>
                        <div class="col-sm-3">
                            <select asp-for="CategoryID" class="form-select" asp-items="@(new SelectList(ViewBag.Categories as List<SV22T1020136.Models.Category> ?? new List<SV22T1020136.Models.Category>(), "CategoryID", "CategoryName"))">
                                <option value="">-- Chọn loại hàng --</option>
                            </select>
                            <span asp-validation-for="CategoryID" class="text-danger"></span>
                        </div>
                        <label class="col-sm-2 col-form-label text-end">Nhà cung cấp</label>
                        <div class="col-sm-4">
                            <select asp-for="SupplierID" class="form-select" asp-items="@(new SelectList(ViewBag.Suppliers as List<SV22T1020136.Models.Supplier> ?? new List<SV22T1020136.Models.Supplier>(), "SupplierID", "SupplierName"))">
                                <option value="">-- Chọn nhà cung cấp --</option>
                            </select>
                            <span asp-validation-for="SupplierID" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Đơn vị tính</label>
                        <div class="col-sm-3">
                            <input asp-for="Unit" class="form-control" placeholder="Cái, hộp, kg..." />
                            <span asp-validation-for="Unit" class="text-danger"></span>
                        </div>

                        <label class="col-sm-2 col-form-label text-end">Giá</label>
                        <div class="col-sm-4">
                            <input asp-for="Price" type="number" step="0.01" min="0" class="form-control money-input" placeholder="Giá bán" />
                            <span asp-validation-for="Price" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Trạng thái</label>
                        <div class="col-sm-9">
                            <div class="form-check form-switch mt-2">
                                <input asp-for="IsSelling" class="form-check-input" />
                                <label class="form-check-label" for="IsSelling">Đang bán</label>
                            </div>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Ảnh đại diện</label>
                        <div class="col-sm-9">
                            @{
                                var previewPhoto = string.IsNullOrWhiteSpace(Model.Photo)
                                    ? Url.Content("~/images/products/nophoto.png")
                                    : (Model.Photo.StartsWith("http", StringComparison.OrdinalIgnoreCase) || Model.Photo.StartsWith("/")
                                        ? Model.Photo
                                        : Url.Content("~/images/products/" + Model.Photo));
                            }
                            <div class="mb-2">
                                <img id="mainPhotoPreview" src="@previewPhoto" class="img-thumbnail" style="max-height:120px;" />
                            </div>
                            <input type="file" name="uploadedMainPhoto" class="form-control mb-2" accept="image/*" data-img-preview="mainPhotoPreview" onchange="previewImage(this)" />
                            <small class="text-muted">Bạn có thể upload ảnh mới tại đây, hoặc chọn ảnh chính trong mục Quản lý ảnh bên dưới.</small>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Mô tả</label>
                        <div class="col-sm-9">
                            <textarea asp-for="ProductDescription" class="form-control" rows="3" placeholder="Nhập mô tả mặt hàng"></textarea>
                            <span asp-validation-for="ProductDescription" class="text-danger"></span>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@if (Model.ProductID > 0)
{
    <div class="card mt-3">
        <div class="card-body d-flex gap-2">
            <a class="btn btn-info" href="@Url.Action("ListPhotos", "Product", new { id = Model.ProductID })">
                <i class="bi bi-images me-1"></i>
                Quản lý ảnh
            </a>
            <a class="btn btn-success" href="@Url.Action("Details", "Product", new { id = Model.ProductID })#attributes">
                <i class="bi bi-list-check me-1"></i>
                Quản lý thuộc tính
            </a>
        </div>
    </div>
}

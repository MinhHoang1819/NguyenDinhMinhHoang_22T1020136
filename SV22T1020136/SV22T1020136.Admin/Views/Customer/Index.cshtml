@model IEnumerable<SV22T1020136.Models.Partner.Customer>
@{
    ViewBag.Title = "Quản lý khách hàng";
}

@section PageToolBar {
    <a href="~/Customer/Create" class="btn btn-primary">
        <i class="bi bi-plus-circle me-1"></i>
        Bổ sung
    </a>
}

<div class="card mb-3">
    <div class="card-body">
        <form id="formSearch" method="get" asp-action="Index" asp-controller="Customer">
            <div class="input-group">
                <input type="text"
                       name="searchValue"
                       value="@(ViewBag.SearchValue ?? "")"
                       class="form-control"
                       placeholder="Tên khách hàng..." autofocus />
                <button class="btn btn-info d-flex align-items-center">
                    <i class="bi bi-search me-1"></i>
                </button>
            </div>
        </form>
    </div>
</div>

<div class="mb-2 text-muted">
    Danh sách này có <strong>@(ViewBag.TotalRecords ?? 0)</strong> khách hàng
</div>

<div class="card">
    <div class="card-body p-1">
        <table class="table table-bordered table-hover mb-0">
            <thead class="table-secondary">
                <tr>
                    <th>Tên khách hàng</th>
                    <th>Tên giao dịch</th>
                    <th>Điện thoại</th>
                    <th>Email</th>
                    <th>Địa chỉ</th>
                    <th>Tỉnh / Thành</th>
                    <th class="text-center" style="width:120px;">Trạng thái</th>
                    <th class="text-center" style="width:100px;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.CustomerName</td>
                            <td>@item.ContactName</td>
                            <td>@item.Phone</td>
                            <td>@item.Email</td>
                            <td>@item.Address</td>
                            <td>@item.Province</td>
                            <td class="text-center">
                                @if (item.IsLocked)
                                {
                                    <span class="badge bg-danger">Khóa</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">Hoạt động</span>
                                }
                            </td>
                            <td class="text-center text-nowrap">
                                <a asp-action="Edit" asp-route-id="@item.CustomerID" class="btn btn-sm btn-primary">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a asp-action="Delete" asp-route-id="@item.CustomerID" class="btn btn-sm btn-danger">
                                    <i class="bi bi-trash"></i>
                                </a>
                                <a asp-action="ChangePassword" asp-route-id="@item.CustomerID" class="btn btn-sm btn-warning ms-2">
                                    <i class="bi bi-key"></i>
                                </a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="8" class="text-center text-muted">Không có dữ liệu</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="card-footer">
        @{
            int totalPages = (int)(ViewBag.TotalPages ?? 1);
            int currentPage = (int)(ViewBag.CurrentPage ?? 1);
            int pageSize = (int)(ViewBag.PageSize ?? ApplicationContext.PageSize);
            string searchValue = ViewBag.SearchValue ?? "";

            var pageSet = new SortedSet<int>();

            for (int i = 1; i <= Math.Min(3, totalPages); i++)
            {
                pageSet.Add(i);
            }

            for (int i = Math.Max(1, currentPage - 1); i <= Math.Min(totalPages, currentPage + 1); i++)
            {
                pageSet.Add(i);
            }

            for (int i = Math.Max(1, totalPages - 1); i <= totalPages; i++)
            {
                pageSet.Add(i);
            }

            var pageList = pageSet.ToList();
        }

        <div class="text-center mb-2">
            <div class="mb-1 text-muted">Tổng cộng: <strong>@totalPages</strong> trang</div>
            <nav aria-label="Pagination">
                <ul class="pagination justify-content-center mb-0">
                    <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                        <a class="page-link"
                           href="@Url.Action("Index", "Customer", new { searchValue, page = Math.Max(1, currentPage - 1), pageSize })"
                           aria-label="Previous">&laquo;</a>
                    </li>

                    @for (int i = 0; i < pageList.Count; i++)
                    {
                        if (i > 0 && pageList[i] - pageList[i - 1] > 1)
                        {
                            <li class="page-item disabled">
                                <span class="page-link">...</span>
                            </li>
                        }

                        var p = pageList[i];
                        <li class="page-item @(p == currentPage ? "active" : "")">
                            <a class="page-link"
                               href="@Url.Action("Index", "Customer", new { searchValue, page = p, pageSize })">@p</a>
                        </li>
                    }

                    <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                        <a class="page-link"
                           href="@Url.Action("Index", "Customer", new { searchValue, page = Math.Min(totalPages, currentPage + 1), pageSize })"
                           aria-label="Next">&raquo;</a>
                    </li>
                </ul>
            </nav>
        </div>
    </div>
</div>

@using SV22T1020136.Models
@using SV22T1020136.Models.Partner
@model SV22T1020136.Models.Supplier

@section PageToolBar {
    <button type="submit" form="formEdit" class="btn btn-primary"><i class="bi bi-save"></i>Lưu dữ liệu</button>
    <a href="~/Supplier" class="btn btn-secondary ms-1"><i class="bi bi-arrow-left"></i>Quay lại</a>
}

<div class="row justify-content-center"><div class="col-12"><div class="card card-primary card-outline">
<div class="card-header"><h5 class="card-title mb-0"><i class="bi bi-truck me-2"></i>Thông tin nhà cung cấp</h5></div>
<div class="card-body">
    <form id="formEdit" method="post" asp-action="Save" asp-controller="Supplier">
        @Html.AntiForgeryToken()
        <input asp-for="SupplierID" type="hidden" />
        <div class="mb-3">
            <label asp-for="SupplierName" class="form-label">Ten nhà cung cấp</label>
            <input asp-for="SupplierName" class="form-control" autofocus /></div>
        <div class="mb-3">
            <label asp-for="ContactName" class="form-label">Tên giao dịch</label>
            <input asp-for="ContactName" class="form-control" /></div>
        <div class="row">
            <div class="col-md-6 mb-3">
                <label asp-for="Phone" class="form-label">Điện thoại</label>
                <input asp-for="Phone" class="form-control" /></div>
            <div class="col-md-6 mb-3">
                <label asp-for="Email" class="form-label">Email</label>
                <input asp-for="Email" type="email" class="form-control" /></div>
        </div>
        <div class="mb-3">
            <label asp-for="Address" class="form-label">Địa chỉ</label>
            <textarea asp-for="Address" class="form-control" rows="3"></textarea></div>
        <div class="mb-3">
            <label asp-for="Province" class="form-label">Tỉnh / Thành</label>
            <input asp-for="Province" class="form-control" /></div>
    </form>
</div>
</div>
</div>
</div>

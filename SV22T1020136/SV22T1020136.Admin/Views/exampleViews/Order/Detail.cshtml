@using SV22T1020136.Models
@using SV22T1020136.Models.Sales
@model SV22T1020136.Models.Order
@{
    ViewBag.Title = "Chi tiết đơn hàng";
}

@section PageToolBar {
    <a href="~/Order" class="btn btn-secondary ms-1"><i class="bi bi-arrow-left"></i> Quay lại</a>
}

@if (TempData["Success"] != null) { <div class="alert alert-success">@TempData["Success"]</div> }
@if (TempData["Error"] != null) { <div class="alert alert-danger">@TempData["Error"]</div> }

<div class="row g-3 mb-3">
    <div class="col-md-8">
        <div class="card card-outline card-primary">
            <div class="card-header"><h5 class="mb-0">Thông tin đơn hàng #@Model.OrderID</h5></div>
            <div class="card-body">
                <div><strong>khách hàng:</strong> @Model.CustomerName</div>
                <div><strong>Ngày đặt:</strong> @Model.OrderTime.ToString("dd/MM/yyyy HH:mm")</div>
                <div><strong>Địa chỉ giao:</strong> @Model.DeliveryAddress</div>
                <div><strong>Tỉnh thành:</strong> @Model.DeliveryProvince</div>
                <div><strong>Trạng thái:</strong> @(Model.StatusDescription ?? Model.Status)</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card card-outline card-info">
            <div class="card-header"><h5 class="mb-0">Xử lý đơn hàng</h5></div>
            <div class="card-body d-grid gap-2">
                <form method="post" asp-action="Accept">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@Model.OrderID" /><button class="btn btn-info">Duyệt đơn hàng</button></form>
                <form method="post" asp-action="Shipping">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@Model.OrderID" /><button class="btn btn-primary">Chuyen giao hang</button></form>
                <form method="post" asp-action="Finish">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@Model.OrderID" /><button class="btn btn-success">Hoàn tất</button></form>
                <form method="post" asp-action="Reject">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@Model.OrderID" /><button class="btn btn-warning">Từ chối</button></form>
                <form method="post" asp-action="Cancel">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@Model.OrderID" /><button class="btn btn-secondary">Hủy đơn</button></form>
                <form method="post" asp-action="Delete" onsubmit="return confirm('Xóa đơn hàng này?');">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@Model.OrderID" /><button class="btn btn-danger">Xóa đơn</button></form>
            </div>
        </div>
    </div>
</div>

<div class="card card-outline card-secondary">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">Danh sách mặt hàng</h5>
        <form method="post" asp-action="ClearCart" onsubmit="return confirm('Xóa tất cả mặt hàng?');">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.OrderID" />
            <button class="btn btn-sm btn-danger">Xóa giỏ hàng</button>
        </form>
    </div>
    <div class="card-body p-1">
        <table class="table table-bordered table-hover mb-0">
            <thead class="table-secondary"><tr><th>ProductID</th><th class="text-center">Số lượng</th><th class="text-end">Gia</th><th class="text-end">Thành tiền</th><th style="width:160px"></th></tr></thead>
            <tbody>
                @if (Model.OrderDetails.Any())
                {
                    foreach (var item in Model.OrderDetails)
                    {
                        <tr>
                            <td>@item.ProductID</td><td class="text-center">@item.Quantity</td><td class="text-end">@item.SalePrice.ToString("N0")</td><td class="text-end">@((item.Quantity * item.SalePrice).ToString("N0"))</td>
                            <td class="text-center text-nowrap">
                                <a href="@Url.Action("EditCartItem", "Order", new { id = Model.OrderID, productId = item.ProductID })" class="btn btn-sm btn-primary"><i class="bi bi-pencil"></i></a>
                                <form method="post" asp-action="DeleteCartItem" style="display:inline" onsubmit="return confirm('Xóa mặt hàng này khỏi đơn?');">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@Model.OrderID" />
                                    <input type="hidden" name="productId" value="@item.ProductID" />
                                    <button class="btn btn-sm btn-danger"><i class="bi bi-trash"></i></button>
                                </form>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="5" class="text-center text-muted">Chưa có mặt hàng</td></tr>
                }
            </tbody>
            <tfoot><tr><th colspan="3" class="text-end">Tổng cộng</th><th class="text-end">@Model.OrderDetails.Sum(x => x.Quantity * x.SalePrice).ToString("N0")</th><th></th></tr></tfoot>
        </table>
    </div>
</div>

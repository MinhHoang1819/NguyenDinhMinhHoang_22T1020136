@using SV22T1020136.Models
@using SV22T1020136.Models.Partner
@model List<SV22T1020136.Models.Partner.Customer>
@{
    ViewBag.Title = "Quản lý khách hàng";
    var searchValue = ViewBag.SearchValue as string ?? "";
    var currentPage = (int)ViewBag.CurrentPage;
    var totalRecords = (int)ViewBag.TotalRecords;
    var totalPages = (int)ViewBag.TotalPages;
}

@section PageToolBar {
    <a href="~/Customer/Create" class="btn btn-primary">
        <i class="bi bi-plus-circle me-1"></i>
        Bổ sung
    </a>
}

<div class="card mb-3">
    <div class="card-body">
        <form method="get" asp-action="Index" asp-controller="Customer">
            <div class="input-group">
                <input type="text" name="searchValue" value="@searchValue" class="form-control" placeholder="Tên khách hàng..." autofocus />
                <button class="btn btn-info d-flex align-items-center">
                    <i class="bi bi-search me-1"></i>
                </button>
            </div>
        </form>
    </div>
</div>

<div class="mb-2 text-muted">
    Danh sách này có <strong>@totalRecords</strong> khách hàng
</div>

<div class="card">
    <div class="card-body p-1">
        <table class="table table-bordered table-hover mb-0">
            <thead class="table-secondary">
                <tr>
                    <th>Tên khách hàng</th>
                    <th>Tên giao dịch</th>
                    <th>Điện thoại</th>
                    <th>Email</th>
                    <th>Địa chỉ</th>
                    <th>Tỉnh / Thành</th>
                    <th class="text-center" style="width:120px;">Trạng thái</th>
                    <th class="text-center" style="width:160px;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.CustomerName</td>
                            <td>@item.ContactName</td>
                            <td>@item.Phone</td>
                            <td>@item.Email</td>
                            <td>@item.Address</td>
                            <td>@item.Province</td>
                            <td class="text-center">
                                @if (item.IsLocked)
                                {
                                    <span class="badge bg-secondary">Đã khóa</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">Hoạt động</span>
                                }
                            </td>
                            <td class="text-center text-nowrap">
                                <a href="@Url.Action("Edit", "Customer", new { id = item.CustomerID })" class="btn btn-sm btn-primary"><i class="bi bi-pencil"></i></a>
                                <a href="@Url.Action("ChangePassword", "Customer", new { id = item.CustomerID })" class="btn btn-sm btn-warning"><i class="bi bi-key"></i></a>
                                <form method="post" asp-action="Delete" asp-controller="Customer" style="display:inline" onsubmit="return confirm('Xóa khách hàng này?');">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@item.CustomerID" />
                                    <button type="submit" class="btn btn-sm btn-danger"><i class="bi bi-trash"></i></button>
                                </form>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="8" class="text-center text-muted">Không có dữ liệu</td></tr>
                }
            </tbody>
        </table>
    </div>
    @if (totalPages > 1)
    {
        <div class="card-footer">
            <ul class="pagination justify-content-center mb-0">
                @for (int p = 1; p <= totalPages; p++)
                {
                    <li class="page-item @(p == currentPage ? "active" : "")">
                        <a class="page-link" href="@Url.Action("Index", new { searchValue, page = p })">@p</a>
                    </li>
                }
            </ul>
        </div>
    }
</div>

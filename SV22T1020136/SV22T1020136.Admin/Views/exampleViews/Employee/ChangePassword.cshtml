@{
    ViewBag.Title = "Mat khau nhân viên";
}

@section PageToolBar {
    <button type="submit" form="formChangePassword" class="btn btn-primary"><i class="bi bi-key me-1"></i>Doi mat khau</button>
    <a href="~/Employee" class="btn btn-secondary ms-1"><i class="bi bi-arrow-left"></i>Quay l?i</a>
}

<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-warning card-outline">
            <div class="card-header"><h5 class="card-title mb-0"><i class="bi bi-shield-lock me-2"></i>Doi mat khau nhân viên</h5></div>
            <div class="card-body">
                <form id="formChangePassword" method="post" asp-action="ChangePassword" asp-controller="Employee">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@(ViewBag.EmployeeID ?? 0)" />

                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger">
                            @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                            {
                                <div>@error.ErrorMessage</div>
                            }
                        </div>
                    }

                    <fieldset class="mb-4">
                        <legend class="fs-6 text-muted mb-3"><i class="bi bi-person me-1"></i>Thong tin nhân viên</legend>
                        <dl class="row mb-0">
                            <dt class="col-sm-3">H? và tên</dt>
                            <dd class="col-sm-9">@(ViewBag.FullName ?? "")</dd>
                        </dl>
                    </fieldset>

                    <div class="mb-3">
                        <label class="form-label">Mat khau moi</label>
                        <input name="newPassword" type="password" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Xac nhan mat khau</label>
                        <input name="confirmPassword" type="password" class="form-control" />
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

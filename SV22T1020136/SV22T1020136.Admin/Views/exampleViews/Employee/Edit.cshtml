@using SV22T1020136.Models
@using SV22T1020136.Models.HR
@model SV22T1020136.Models.Employee

@section PageToolBar {
    <button type="submit" form="formEdit" class="btn btn-primary"><i class="bi bi-save"></i> Lưu dữ liệu</button>
    <a href="~/Employee" class="btn btn-secondary ms-1"><i class="bi bi-arrow-left"></i> Quay l?i</a>
}

<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-primary card-outline">
            <div class="card-header"><h5 class="card-title mb-0"><i class="bi bi-person-badge me-2"></i>Thong tin nhân viên</h5></div>
            <div class="card-body">
                <form id="formEdit" method="post" asp-action="Save" asp-controller="Employee">
                    @Html.AntiForgeryToken()
                    <input asp-for="EmployeeID" type="hidden" />
                    <input asp-for="Photo" type="hidden" />
                    <input asp-for="Password" type="hidden" />
                    <input asp-for="RoleNames" type="hidden" />

                    <div class="row mb-3">
                        <div class="col-md-7">
                            <label asp-for="FullName" class="form-label">H? và tên</label>
                            <input asp-for="FullName" class="form-control" autofocus />
                        </div>
                        <div class="col-md-5">
                            <label asp-for="BirthDate" class="form-label">Ngày sinh</label>
                            <input asp-for="BirthDate" type="date" class="form-control" />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Address" class="form-label">??a ch?</label>
                        <textarea asp-for="Address" class="form-control" rows="3"></textarea>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-5">
                            <label asp-for="Phone" class="form-label">Điện thoại</label>
                            <input asp-for="Phone" class="form-control" />
                        </div>
                        <div class="col-md-7">
                            <label asp-for="Email" class="form-label">Email</label>
                            <input asp-for="Email" type="email" class="form-control" />
                        </div>
                    </div>

                    <div class="form-check form-switch mt-2">
                        <input asp-for="IsWorking" class="form-check-input" type="checkbox" id="IsWorking" />
                        <label class="form-check-label" for="IsWorking">?ang làm vi?c</label>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

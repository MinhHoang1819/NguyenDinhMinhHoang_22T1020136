@using SV22T1020136.Models
@using SV22T1020136.Models.Catalog
@model SV22T1020136.Models.ProductPhoto
@{
    ViewData["Title"] = "Thêm Hình Ảnh";
    var productID = ViewBag.ProductID as int? ?? 0;
    var productName = ViewBag.ProductName as string ?? "";
}

<div class="row justify-content-center">
    <div class="col-md-8">
            <div class="card-header">
                <h3 class="card-title">
                    <i class="bi bi-image me-2"></i>Thêm Hình Ảnh
                </h3>
            </div>
            <form id="photoForm" asp-action="SavePhoto" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <!-- Multiple ways to ensure ProductID is sent -->
                <input type="hidden" name="productId" value="@productID" />
                <input type="hidden" name="ProductID" value="@productID" />
                @* IMPORTANT: Do NOT use "photo.ProductID" here.
                   If a "photo.*" key exists, ASP.NET Core will bind ProductPhoto photo using the "photo" prefix,
                   and unprefixed fields like name="Photo" will be ignored -> URL mode fails. *@
                <div class="card-body">
                    <div class="alert alert-info">
                        <i class="bi bi-info-circle me-2"></i>
                        <strong>Sản phẩm:</strong> @productName
                    </div>

                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            <i class="bi bi-exclamation-triangle me-2"></i>
                            @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                            {
                                <div>@error.ErrorMessage</div>
                            }
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }

                    <!-- Tab Navigation -->
                    <ul class="nav nav-tabs mb-3" id="photoTabs" role="tablist">
                        <li class="nav-item" role="presentation">
                            <button class="nav-link active" id="upload-tab" data-bs-toggle="tab" data-bs-target="#upload" type="button" role="tab">
                                <i class="bi bi-upload me-1"></i>Tải lên từ máy
                            </button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link" id="url-tab" data-bs-toggle="tab" data-bs-target="#url" type="button" role="tab">
                                <i class="bi bi-link me-1"></i>Nhập URL
                            </button>
                        </li>
                    </ul>

                    <!-- Tab Content -->
                    <div class="tab-content" id="photoTabsContent">
                        <!-- Upload Tab -->
                        <div class="tab-pane fade show active" id="upload" role="tabpanel">
                            <div class="form-group mb-3">
                                <label for="uploadedFile">
                                    <i class="bi bi-image me-1"></i>Chọn file ảnh
                                </label>
                                <input type="file" 
                                       name="uploadedFile" 
                                       id="uploadedFile"
                                       class="form-control" 
                                       accept="image/*"
                                       onchange="previewImage(this)" />
                                <small class="form-text text-muted">
                                    Chọn file ảnh từ máy tính (JPG, PNG, GIF...)
                                </small>
                            </div>
                            <div id="imagePreview" class="text-center mb-3" style="display: none;">
                                <img id="preview" src="" alt="Preview" class="img-thumbnail" style="max-height: 300px;" />
                            </div>
                        </div>

                        <!-- URL Tab -->
                        <div class="tab-pane fade" id="url" role="tabpanel">
                            <div class="form-group mb-3">
                                <label for="PhotoUrl">
                                    <i class="bi bi-link me-1"></i>URL Hình ảnh
                                </label>
                                <input type="text" 
                                       id="PhotoUrl"
                                       name="Photo"
                                       class="form-control" 
                                       placeholder="https://..."
                                       value="@Model.Photo" />
                                <small class="form-text text-muted">
                                    Nhập đường dẫn URL của hình ảnh
                                </small>
                            </div>
                        </div>
                    </div>

                    <div class="form-group mb-3">
                        <label for="Description">
                            <i class="bi bi-card-text me-1"></i>Mô tả
                        </label>
                        <input type="text" 
                               asp-for="Description" 
                               class="form-control" 
                               placeholder="Mô tả hình ảnh..." />
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label for="DisplayOrder">
                                    <i class="bi bi-sort-numeric-down me-1"></i>Thứ tự hiển thị
                                </label>
                                <input type="number" 
                                       asp-for="DisplayOrder" 
                                       class="form-control" 
                                       placeholder="0"
                                       min="0" />
                                <small class="form-text text-muted">
                                    Số càng nhỏ càng hiển thị trước
                                </small>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>&nbsp;</label>
                                <div class="form-check">
                                    <input type="checkbox" 
                                           asp-for="IsHidden" 
                                           class="form-check-input" 
                                           id="IsHidden" />
                                    <label class="form-check-label" for="IsHidden">
                                        <i class="bi bi-eye-slash me-1"></i>Ẩn hình ảnh
                                    </label>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="card-footer">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-circle me-2"></i>Lưu
                    </button>
                    <a href="@Url.Action("ListPhotos", "Product", new { id = productID })" class="btn btn-secondary">
                        <i class="bi bi-x-circle me-2"></i>Hủy
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
function previewImage(input) {
    if (input.files && input.files[0]) {
        var reader = new FileReader();
        
        reader.onload = function(e) {
            document.getElementById('preview').src = e.target.result;
            document.getElementById('imagePreview').style.display = 'block';
        }
        
        reader.readAsDataURL(input.files[0]);
    }
}

// Clear file input when switching to URL tab
document.getElementById('url-tab').addEventListener('click', function() {
    document.getElementById('uploadedFile').value = '';
    document.getElementById('imagePreview').style.display = 'none';
});

// Debug: Log values before submit
document.getElementById('photoForm').addEventListener('submit', function(e) {
    var photoUrl = document.getElementById('PhotoUrl').value;
    var fileInput = document.getElementById('uploadedFile').files.length;
    
    console.log('=== SUBMIT DEBUG ===');
    console.log('PhotoUrl value:', photoUrl);
    console.log('File selected:', fileInput > 0);
    console.log('All form data:');
    var formData = new FormData(this);
    for (var pair of formData.entries()) {
        console.log(pair[0] + ': ' + pair[1]);
    }
});
</script>

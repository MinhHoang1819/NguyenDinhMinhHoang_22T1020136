@using SV22T1020136.Models
@using SV22T1020136.Models.Catalog
@using SV22T1020136.Models.Partner
@model SV22T1020136.Models.Product

@section PageToolBar {
    <button type="submit" form="formEdit" class="btn btn-primary"><i class="bi bi-save"></i> Lưu dữ liệu</button>
    <a href="~/Product" class="btn btn-secondary ms-1"><i class="bi bi-arrow-left"></i> Quay lại</a>
}

<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-primary card-outline">
            <div class="card-header"><h5 class="card-title mb-0"><i class="bi bi-box-seam me-2"></i>Thông tin mặt hàng</h5></div>
            <div class="card-body">
                <form id="formEdit" method="post" asp-action="Save" asp-controller="Product">
                    @Html.AntiForgeryToken()
                    <input asp-for="ProductID" type="hidden" />
                    <input asp-for="Photo" type="hidden" />

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Tên mặt hàng</label>
                        <div class="col-sm-9"><input asp-for="ProductName" class="form-control" autofocus /></div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">lo?i hàng</label>
                        <div class="col-sm-3">
                            <select asp-for="CategoryID" class="form-select" asp-items="@(new SelectList(ViewBag.Categories as List<SV22T1020136.Models.Category> ?? new List<SV22T1020136.Models.Category>(), "CategoryID", "CategoryName"))">
                                <option value="">-- Chon lo?i hàng --</option>
                            </select>
                        </div>
                        <label class="col-sm-2 col-form-label text-end">nhà cung c?p</label>
                        <div class="col-sm-4">
                            <select asp-for="SupplierID" class="form-select" asp-items="@(new SelectList(ViewBag.Suppliers as List<SV22T1020136.Models.Supplier> ?? new List<SV22T1020136.Models.Supplier>(), "SupplierID", "SupplierName"))">
                                <option value="">-- Chon nhà cung c?p --</option>
                            </select>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Don vi tinh</label>
                        <div class="col-sm-3"><input asp-for="Unit" class="form-control" /></div>
                        <label class="col-sm-2 col-form-label text-end">Gia</label>
                        <div class="col-sm-4"><input asp-for="Price" type="number" step="0.01" min="0" class="form-control" /></div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Anh dai dien (URL)</label>
                        <div class="col-sm-9"><input asp-for="Photo" class="form-control" placeholder="/images/products/... hoac https://..." /></div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Trạng thái</label>
                        <div class="col-sm-9"><div class="form-check form-switch mt-2"><input asp-for="IsSelling" class="form-check-input" /><label class="form-check-label" for="IsSelling">Dang ban</label></div></div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Mo ta</label>
                        <div class="col-sm-9"><textarea asp-for="ProductDescription" class="form-control" rows="3"></textarea></div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@using SV22T1020136.Models
@using SV22T1020136.Models.Catalog
@model SV22T1020136.Models.ProductAttribute
@{
    ViewData["Title"] = "Thêm Thuộc Tính";
    var productID = ViewBag.ProductID as int? ?? 0;
    var productName = ViewBag.ProductName as string ?? "";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card card-primary">
            <div class="card-header">
                <h3 class="card-title">
                    <i class="bi bi-tags me-2"></i>Thêm Thuộc Tính
                </h3>
            </div>
            <form asp-action="SaveAttribute" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="ProductID" />
                <div class="card-body">
                    <div class="alert alert-info">
                        <i class="bi bi-info-circle me-2"></i>
                        <strong>Sản phẩm:</strong> @productName
                    </div>

                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            <i class="bi bi-exclamation-triangle me-2"></i>
                            @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                            {
                                <div>@error.ErrorMessage</div>
                            }
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }

                    <div class="form-group mb-3">
                        <label for="AttributeName">
                            <i class="bi bi-tag me-1"></i>Tên thuộc tính <span class="text-danger">*</span>
                        </label>
                        <input type="text" 
                               asp-for="AttributeName" 
                               class="form-control" 
                               placeholder="Ví dụ: Màu sắc, Kích thước, Dung tích..."
                               required />
                    </div>

                    <div class="form-group mb-3">
                        <label for="AttributeValue">
                            <i class="bi bi-card-text me-1"></i>Giá trị <span class="text-danger">*</span>
                        </label>
                        <input type="text" 
                               asp-for="AttributeValue" 
                               class="form-control" 
                               placeholder="Ví dụ: Đỏ, XL, 500ml..."
                               required />
                    </div>

                    <div class="form-group mb-3">
                        <label for="DisplayOrder">
                            <i class="bi bi-sort-numeric-down me-1"></i>Thứ tự hiển thị
                        </label>
                        <input type="number" 
                               asp-for="DisplayOrder" 
                               class="form-control" 
                               placeholder="0"
                               min="0" />
                        <small class="form-text text-muted">
                            Số càng nhỏ càng hiển thị trước
                        </small>
                    </div>
                </div>
                <div class="card-footer">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-circle me-2"></i>Lưu
                    </button>
                    <a href="@Url.Action("Details", "Product", new { id = productID })" class="btn btn-secondary">
                        <i class="bi bi-x-circle me-2"></i>Hủy
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

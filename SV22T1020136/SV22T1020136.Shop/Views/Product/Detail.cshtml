@model Product
@{
    ViewData["Title"] = Model.ProductName;
    var photos = (ViewBag.Photos as List<ProductPhoto> ?? new()).Where(p => !p.IsHidden).OrderBy(p => p.DisplayOrder).ToList();
    var attrs = ViewBag.Attributes as List<ProductAttribute> ?? new();
    var related = ViewBag.RelatedProducts as List<Product> ?? new();
    var gallery = new List<string> { ShopUi.ProductImage(Model.Photo) };
    gallery.AddRange(photos.Select(p => ShopUi.ProductImage(p.Photo)).Where(p => !gallery.Contains(p)));
}

<div class="container py-4 product-detail-page book-detail-layout">
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Trang chủ</a></li>
            <li class="breadcrumb-item"><a asp-controller="Product" asp-action="Index">Cửa hàng</a></li>
            <li class="breadcrumb-item active">@Model.ProductName</li>
        </ol>
    </nav>

    <div class="detail-page-card mb-4 reveal product-detail-main">
        <div class="row g-4 g-lg-5 align-items-start">
            <div class="col-lg-6 col-xl-5">
                <div class="product-detail-gallery text-center mb-3 rounded-3 p-3 book-cover-stage">
                    <img id="mainImage" src="@gallery.First()" class="img-fluid detail-main-image" style="max-height: 420px; object-fit: contain;" alt="@Model.ProductName" onerror="this.onerror=null;this.src='@ShopUi.ProductPlaceholder';" />
                </div>
                @if (gallery.Count > 1)
                {
                    <div class="d-flex gap-2 justify-content-center detail-gallery flex-wrap">
                        @foreach (var image in gallery)
                        {
                            <img src="@image" class="img-thumbnail" style="width: 60px; height: 60px; object-fit: contain; cursor: pointer;" onclick="document.getElementById('mainImage').src=this.src" alt="@Model.ProductName" onerror="this.onerror=null;this.src='@ShopUi.ProductPlaceholder';" />
                        }
                    </div>
                }
            </div>

            <div class="col-lg-6 col-xl-7">
                <div class="product-detail-sticky">
                    <h1 class="fw-bold fs-3 mb-3">@Model.ProductName</h1>
                    <div class="detail-price detail-price--hero mb-3">@Model.Price.ToString("N0") đ</div>

                    <table class="table table-sm mb-3" style="max-width: 320px;">
                        <tr><td class="text-muted">Đơn vị tính</td><td class="fw-bold">@Model.Unit</td></tr>
                        <tr>
                            <td class="text-muted">Trạng thái</td>
                            <td>
                                @if (Model.IsSelling)
                                {
                                    <span class="badge bg-success">Còn hàng</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Tạm hết hàng</span>
                                }
                            </td>
                        </tr>
                    </table>

                    @if (Model.IsSelling)
                    {
                        <form asp-controller="Cart" asp-action="AddToCart" method="post" class="d-flex align-items-center gap-3 mb-3 flex-wrap">
                            <input type="hidden" name="productId" value="@Model.ProductID" />
                            <div class="quantity-control">
                                <label class="form-label mb-0 me-2">Số lượng</label>
                                <input type="number" name="quantity" value="1" min="1" class="form-control" style="width: 90px;" />
                            </div>
                            <button type="submit" class="btn btn-primary btn-lg">
                                <i class="bi bi-cart-plus me-2"></i>Thêm vào giỏ hàng
                            </button>
                        </form>
                    }

                    @if (!string.IsNullOrWhiteSpace(Model.ProductDescription))
                    {
                        <div class="mt-3">
                            <h6 class="fw-bold">Mô tả sản phẩm</h6>
                            <p class="text-muted">@Model.ProductDescription</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    @if (attrs.Any())
    {
        <div class="detail-page-card mb-4 reveal">
            <h4 class="fw-bold mb-3"><i class="bi bi-list-check me-2"></i>Thông tin thêm</h4>
            <table class="table table-striped mb-0">
                @foreach (var a in attrs.OrderBy(x => x.DisplayOrder))
                {
                    <tr>
                        <td class="fw-bold" style="width: 200px;">@a.AttributeName</td>
                        <td>@a.AttributeValue</td>
                    </tr>
                }
            </table>
        </div>
    }

    @if (related.Any())
    {
        <div class="mb-4">
            <h4 class="section-title">Sản phẩm liên quan</h4>
            <div class="row g-3 reveal-stagger">
                @foreach (var p in related)
                {
                    <div class="col-6 col-md-3">
                        <div class="product-card reveal h-100">
                            <a asp-action="Detail" asp-route-id="@p.ProductID">
                                <div class="card-img-wrap">
                                    <img src="@ShopUi.ProductImage(p.Photo)" alt="@p.ProductName" onerror="this.onerror=null;this.src='@ShopUi.ProductPlaceholder';" />
                                </div>
                            </a>
                            <div class="card-body">
                                <a class="product-name" asp-action="Detail" asp-route-id="@p.ProductID">@p.ProductName</a>
                                <div class="product-price">@p.Price.ToString("N0") đ</div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
</div>

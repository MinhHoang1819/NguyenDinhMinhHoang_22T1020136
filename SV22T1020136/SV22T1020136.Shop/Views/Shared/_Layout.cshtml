@{
    var cart = ApplicationContext.GetSessionData<List<CartItem>>("Cart") ?? new List<CartItem>();
    var cartCount = cart.Sum(c => c.Quantity);
    var isAuthenticated = User.Identity?.IsAuthenticated == true;
    var customerName = User.Identity?.Name ?? "";
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewData["Title"] != null ? ViewData["Title"] + " - " : "")@ShopUi.BrandName</title>
    <link rel="icon" type="image/x-icon" href="~/favicon.ico" asp-append-version="true" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=Fraunces:wght@600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header class="site-header" id="siteHeader">
        <div class="container">
            <div class="site-header__grid">
                <button class="btn btn-menu site-header__menu d-lg-none" type="button" data-bs-toggle="offcanvas" data-bs-target="#shopNavOffcanvas" aria-controls="shopNavOffcanvas" aria-label="Mở menu">
                    <i class="bi bi-list"></i>
                </button>

                <a class="site-brand site-header__brand text-decoration-none" asp-controller="Home" asp-action="Index" title="@ShopUi.BrandName">
                    <span class="site-brand__logo d-inline-flex align-items-center justify-content-center">MH</span>
                    <span class="site-brand__text">@ShopUi.BrandName</span>
                </a>

                <form class="header-search site-header__search d-flex" asp-controller="Product" asp-action="Index" method="get">
                    <input type="text" name="search" class="form-control" placeholder="Tìm sản phẩm, danh mục..." value="@Context.Request.Query["search"]" />
                    <button class="btn btn-search" type="submit" aria-label="Tìm kiếm">
                        <i class="bi bi-search"></i>
                    </button>
                </form>

                <div class="site-header__end d-flex align-items-center gap-2 gap-lg-3 flex-shrink-0 ms-lg-auto">
                    <nav class="header-nav-quick site-header__nav d-none d-lg-flex align-items-center flex-shrink-0" aria-label="Điều hướng chính">
                        <a class="header-nav-quick__link @(currentController == "Home" && currentAction == "Index" ? "is-active" : "")" asp-controller="Home" asp-action="Index">Trang chủ</a>
                        <a class="header-nav-quick__link @(currentController == "Product" ? "is-active" : "")" asp-controller="Product" asp-action="Index">Cửa hàng</a>
                    </nav>

                    <div class="site-header__actions d-flex align-items-center gap-2 gap-lg-3 flex-shrink-0">
                        <a class="header-action" asp-controller="Cart" asp-action="Index">
                            <span class="position-relative">
                                <i class="bi bi-cart3"></i>
                                @if (cartCount > 0)
                                {
                                    <span class="cart-badge">@cartCount</span>
                                }
                            </span>
                            <span class="d-none d-xl-inline">Giỏ hàng</span>
                        </a>

                        @if (isAuthenticated)
                        {
                            <div class="dropdown">
                                <a class="header-action dropdown-toggle" href="#" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="bi bi-person-circle"></i>
                                    <span class="d-none d-xl-inline text-truncate" style="max-width: 7rem">@customerName</span>
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end">
                                    <li><a class="dropdown-item" asp-controller="Account" asp-action="Profile"><i class="bi bi-person me-2"></i>Tài khoản</a></li>
                                    <li><a class="dropdown-item" asp-controller="Order" asp-action="History"><i class="bi bi-bag-check me-2"></i>Đơn hàng</a></li>
                                    <li><a class="dropdown-item" asp-controller="Account" asp-action="ChangePassword"><i class="bi bi-key me-2"></i>Đổi mật khẩu</a></li>
                                    <li><hr class="dropdown-divider" /></li>
                                    <li><a class="dropdown-item text-danger" asp-controller="Account" asp-action="Logout"><i class="bi bi-box-arrow-right me-2"></i>Đăng xuất</a></li>
                                </ul>
                            </div>
                        }
                        else
                        {
                            <a class="header-action" asp-controller="Account" asp-action="Login">
                                <i class="bi bi-person"></i>
                                <span class="d-none d-xl-inline">Đăng nhập</span>
                            </a>
                        }
                    </div>
                </div>
            </div>

            <div class="site-header__meta header-trust header-trust--ribbon d-none d-sm-flex justify-content-center align-items-center flex-wrap">
                <span class="header-trust__item"><i class="bi bi-telephone"></i> 0332314181</span>
                <span class="header-trust__sep" aria-hidden="true">·</span>
                <span class="header-trust__item"><i class="bi bi-truck"></i> Giao hàng nhanh, thanh toán rõ ràng</span>
            </div>
        </div>
    </header>

    <div class="offcanvas offcanvas-start offcanvas-nav" tabindex="-1" id="shopNavOffcanvas" aria-labelledby="shopNavOffcanvasLabel">
        <div class="offcanvas-header border-bottom align-items-center">
            <div class="d-flex align-items-center gap-2 mb-0" id="shopNavOffcanvasLabel">
                <span class="site-brand__logo d-inline-flex align-items-center justify-content-center">MH</span>
                <span class="fw-bold">@ShopUi.BrandName</span>
            </div>
            <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Đóng"></button>
        </div>
        <div class="offcanvas-body">
            <ul class="nav flex-column gap-1">
                <li class="nav-item">
                    <a class="nav-link rounded-pill px-3 @(currentController == "Home" && currentAction == "Index" ? "active" : "")" asp-controller="Home" asp-action="Index"><i class="bi bi-house-door me-2"></i>Trang chủ</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link rounded-pill px-3 @(currentController == "Product" ? "active" : "")" asp-controller="Product" asp-action="Index"><i class="bi bi-shop-window me-2"></i>Cửa hàng</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link rounded-pill px-3 @(currentController == "Cart" ? "active" : "")" asp-controller="Cart" asp-action="Index"><i class="bi bi-cart3 me-2"></i>Giỏ hàng</a>
                </li>
            </ul>
        </div>
    </div>

    <main class="site-main py-4">
        @RenderBody()
    </main>

    <button type="button" id="backToTop" class="back-to-top" aria-label="Về đầu trang" title="Về đầu trang">
        <i class="bi bi-arrow-up back-to-top__icon" aria-hidden="true"></i>
    </button>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

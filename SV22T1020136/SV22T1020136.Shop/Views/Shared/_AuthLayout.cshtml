<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewData["Title"] != null ? ViewData["Title"] + " - " : "")@ShopUi.BrandName</title>
    <link rel="icon" type="image/x-icon" href="~/favicon.ico" asp-append-version="true" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=Fraunces:wght@600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="auth-shell">
    <div class="auth-shell__main">
        <a class="auth-shell__brand d-inline-flex align-items-center gap-2 justify-content-center text-decoration-none" asp-controller="Home" asp-action="Index" title="Về trang chủ @ShopUi.BrandName">
            <span class="site-brand__logo d-inline-flex align-items-center justify-content-center">MH</span>
            <span class="site-brand__text">@ShopUi.BrandName</span>
        </a>
        @RenderBody()
        <nav class="auth-shell__footer text-center mt-4" aria-label="Điều hướng">
            <a asp-controller="Home" asp-action="Index" class="auth-shell__home-link">
                <i class="bi bi-arrow-left-short" aria-hidden="true"></i> Về trang chủ
            </a>
        </nav>
    </div>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
